{
  "project": {
    "name": "Bob",
    "environment": "development",
    "log_level": "INFO"
  },
  "assistant": {
    "name": "Bob",
    "wake_phrase": "Hey Bob",
    "deterministic_reply": "Hello, I'm here.",
    "start_muted": false
  },
  "timeouts": {
    "listen_seconds": 8,
    "response_start_seconds": 3,
    "network_fallback_seconds": 5
  },
  "audio": {
    "input_device": "default",
    "output_device": "default",
    "sample_rate_hz": 16000,
    "watchdog_timeout_seconds": 5
  },
  "actions": {
    "open_app": {
      "enabled": true,
      "aliases": {
        "calculator": "calc.exe",
        "notepad": "notepad.exe"
      }
    }
  },
  "stt": {
    "engine": "vosk",
    "model_path": "models/vosk/vosk-model-small-en-us-0.15",
    "language": "en",
    "sample_rate_hz": 16000,
    "fallback_engine": null
  },
  "tts": {
    "engine": "pyttsx3",
    "speech_rate": 150,
    "voice_id": null
  },
  "observability": {
    "logs_directory": "logs",
    "log_filename": "bob.log",
    "log_max_bytes": 1048576,
    "log_backup_count": 3,
    "health_summary_interval_seconds": 300
  }
}
